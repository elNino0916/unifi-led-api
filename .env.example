# UniFi LED API Configuration
# Copy this file to .env and fill in your values.
# Usage: The app loads this automatically — no need to source anything.

UNIFI_USER=your_username
UNIFI_PASS=your_password
UNIFI_CONTROLLER=https://your-unifi-controller-ip
UNIFI_DEVICE_ID=your_device_id
# For multiple devices, use a comma-separated list:
# UNIFI_DEVICE_ID=device_id_1,device_id_2,device_id_3
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false
